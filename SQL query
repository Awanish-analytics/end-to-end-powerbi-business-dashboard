-- third query 



SELECT 
    o.org_id,
    o.organisation_name,

    COUNT(DISTINCT xihn.invoice_id) AS total_invoices,

    COUNT(DISTINCT CASE 
        WHEN xihn.history_notes LIKE 
             '%Received through the Xero API from Control by Traffic New Zealand%' 
        THEN xihn.invoice_id 
    END) AS invoices_sent_to_xero_using_control,

    (
        COUNT(DISTINCT xihn.invoice_id) 
        - COUNT(DISTINCT CASE 
              WHEN xihn.history_notes LIKE 
                   '%Received through the Xero API from Control by Traffic New Zealand%' 
              THEN xihn.invoice_id 
          END)
    ) AS invoices_sent_to_xero_without_using_control,

    CASE 
        WHEN COUNT(DISTINCT xihn.invoice_id) = 
             COUNT(DISTINCT CASE 
                 WHEN xihn.history_notes LIKE 
                      '%Received through the Xero API from Control by Traffic New Zealand%' 
                 THEN xihn.invoice_id 
             END)
        THEN 'Compliant'
        ELSE 'Non-Compliant'
    END AS control_invoicing_status

FROM organisation o
JOIN xero_app_user_tenant xaut 
    ON xaut.id = o.xero_app_user_tenant_id
JOIN xero_invoice_history_notes xihn 
    ON xihn.tenant_id::text = xaut.tenant_id

WHERE xihn.dateutcstring::timestamp between DATE '2026-02-01' AND current_date

GROUP BY 
    o.org_id, 
    o.organisation_name

ORDER BY 
    o.organisation_name ASC;






--fourth query 



SELECT *,
       minimum_annual_revenue - Last_12_months_revenue
	   
       AS revenue_difference
FROM (
    SELECT 
           f.control_organisation_name,
		   f.franchisee_name,
           f.id,
           fm.minimum_annual_revenue, 
           fm.minimum_monthly_revenue,
           xple.local_marketing_amount AS actual_marketing_spend,
           
           COALESCE(xple.total_income,0) 
           + COALESCE(xple.total_other_income,0) 
           AS Last_12_months_revenue
		   
    FROM franchisee f 
    JOIN franchisee_marketing fm 
         ON f.id = fm.franchisee_id 
    JOIN xero_profit_loss_etl xple 
         ON fm.franchisee_id = xple.org_id
	
) t;



--fifth query 



SELECT 
    d.deal_id,
    d.status,
    d.date_allocated,
    DATE_TRUNC('month', d.date_allocated) AS lead_month,
    
    d.referral_source_category,
	d.discontinued_reason,
	--select * from deal limit 50
    
    o.org_id,
    o.organisation_name,

    c.country_id,
    c.name AS country_name,
    
    s.display_name AS stage_name,
    s.stage_order

FROM deal d

JOIN organisation o
    ON d.org_id = o.org_id

JOIN country c
    ON o.country_id = c.country_id

JOIN deal_stage ds
    ON d.deal_id = ds.deal_id

JOIN stage s
    ON ds.stage_id = s.stage_id

WHERE 
    d.status IN ('A','C','D','H')
    AND d.date_allocated >= CURRENT_DATE - INTERVAL '12 months'

    AND s.stage_order = (
        SELECT MAX(s2.stage_order)
        FROM deal_stage ds2
        JOIN stage s2 
            ON ds2.stage_id = s2.stage_id
        WHERE ds2.deal_id = d.deal_id
    );


--fifth query 


SELECT
    d.deal_id,

    CASE
        WHEN s.display_name = 'Lead In' THEN 'Lead In'
        WHEN s.display_name IN ('Initial Consultation','Briefing') THEN 'Initial Consultation'
        WHEN s.display_name IN ('Concept & Feasibility','Concept & Estimation') THEN 'Scoping & Feasibility'
        WHEN s.display_name IN ('Working Drawings & Costing','Detailed Design & Costing') THEN 'Detailed Planning & Costing'
        WHEN s.display_name = 'Build Stage' THEN 'Build Stage'
        WHEN s.display_name = 'Project Closure' THEN 'Project Completion'
        ELSE s.display_name
    END AS standardized_stage,

    o.organisation_name,

    SUM(pid.item_price) AS total_item_price,

    MAX(p.project_price) AS total_project_price,

    SUM(pid.item_price) + MAX(p.project_price) AS total_price

FROM organisation o
JOIN deal d ON o.org_id = d.org_id
JOIN pricing_version pv ON d.deal_id = pv.project_id
JOIN pricing p ON pv.pricing_version_id = p.pricing_version_id
JOIN stage s ON pv.stage_id = s.stage_id
JOIN pricing_group pg ON pg.pricing_id = p.pricing_id
JOIN pricing_group_items pgi ON pg.pricing_group_id = pgi.pricing_group_id
JOIN pricing_item_details pid ON pgi.pricing_item_detail_id = pid.pricing_item_detail_id

WHERE
    d.status IN ('A','C')
    AND pg.margin_price <> 0
    AND pv.is_sent_to_invoice = true
	--AND o.organisation_name = 'NZ-MW01 | Wayne Gordon'
    --AND d.deal_id = '27d49d1f-2e7f-4eac-ac36-aa3dc3172580'

GROUP BY
    d.deal_id,
    standardized_stage,
    o.organisation_name

ORDER BY
    d.deal_id,
    standardized_stage;



--six query 



SELECT 
    o.organisation_name,

    CASE 
        WHEN s.display_name = 'Lead In'
            THEN 'Lead In'

        WHEN s.display_name IN ('Initial Consultation','Briefing')
            THEN 'Initial Consultation'

        WHEN s.display_name IN ('Concept & Feasibility','Concept & Estimation')
            THEN 'Scoping & Feasibility'

        WHEN s.display_name IN ('Working Drawings & Costing','Detailed Design & Costing')
            THEN 'Detailed Planning & Costing'

        WHEN s.display_name = 'Build Stage'
            THEN 'Build Stage'

        WHEN s.display_name = 'Project Closure'
            THEN 'Project Completion'
    END AS stage_name,

    COUNT(DISTINCT d.deal_id) AS deal_count

FROM stage s

JOIN deal_stage ds
ON s.stage_id = ds.stage_id

JOIN deal d
ON ds.deal_id = d.deal_id

JOIN organisation o
ON d.org_id = o.org_id

WHERE d.date_allocated >= CURRENT_DATE - INTERVAL '12 months'

GROUP BY 
    o.organisation_name,
    stage_name

ORDER BY 
    o.organisation_name,
    stage_name;


